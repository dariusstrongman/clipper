# Twitch (https://dev.twitch.tv/console/apps)
# Either TWITCH_CLIENT_SECRET (preferred - auto-refreshes)
# or TWITCH_APP_ACCESS_TOKEN (quick path - expires in ~60 days)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_APP_ACCESS_TOKEN=

# Supabase (same project as stromation/resumego - service role key required for writes)
SUPABASE_URL=https://iadzcnzgbtuigyodeqas.supabase.co
SUPABASE_SERVICE_KEY=

# OpenAI (for Whisper captions + GPT title/hashtag generation)
OPENAI_API_KEY=

# Paths (server defaults; adjust if running elsewhere)
DATA_DIR=/mnt/clipper-storage/clipper
LOG_DIR=/mnt/clipper-storage/clipper/logs

# Streamers (comma-separated Twitch usernames, lowercase)
STREAMERS=ddg,marlon,jasontheween,lacy

# Polling + detection tuning
POLL_INTERVAL_SECONDS=30
CHAT_SPIKE_WINDOW_SECONDS=5
CHAT_SPIKE_MIN_MSGS=40
CHAT_SPIKE_COOLDOWN_SECONDS=90
CLIP_PRE_SECONDS=12
CLIP_POST_SECONDS=18
BUFFER_MAX_MINUTES=10

# YouTube upload (filled in later once channel exists)
YOUTUBE_CLIENT_SECRET_FILE=/home/ubuntu/clipper/youtube_client_secret.json
YOUTUBE_CHANNEL_ID=
